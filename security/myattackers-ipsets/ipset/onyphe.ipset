# AS213412 - ONYPHE
#: ipset -exist restore <ipset/onyphe.ipset
#: iptables -w -I myattackers-ipset -m set --match-set onyphe src -j REJECT
create onyphe hash:net family inet hashsize 64 maxelem 32
flush onyphe
